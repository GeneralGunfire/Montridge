# Database Configuration
# Use DATABASE_URL for Neon (PostgreSQL hosted)
DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require&channel_binding=require

# OR use local database credentials (fallback)
DB_NAME=montridge_db
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# API Keys
GROQ_API_KEY=
GROQ_API_KEY_2=

# Authentication
JWT_SECRET_KEY=your-secret-key-here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
