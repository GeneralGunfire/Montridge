# Groq API Keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_KEY_2=your_second_groq_key_here

# Database Configuration
DB_NAME=montridge_db
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432

# Flask/JWT Configuration
JWT_SECRET_KEY=your_jwt_secret_here

# Deployment
FLASK_ENV=production
PORT=5000

# Frontend URL (for CORS - use Vercel deployment URL)
FRONTEND_URL=https://montridge-frontend.vercel.app
